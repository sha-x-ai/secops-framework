###############################################################################
# SOC Framework – .gitignore
###############################################################################

# ----------------------------------------
# PYTHON
# ----------------------------------------
__pycache__/
*.pyc
*.pyo

# Virtual environments
venv/
.env
.env.*

# ----------------------------------------
# BUILD ARTIFACTS (NEVER COMMIT)
# ----------------------------------------

# demisto-sdk directories
uploadable_packs/
artifacts/
dist/

# Workflow-generated config assets
*-staging-xsoar_config.json
*-main-xsoar_config.json

# editor-specific
.vscode/
.idea/
.claude/

# macOS
.DS_Store

# Logs
logs/
*.log
sdk_errors.txt

# Keypair material
*.pem

# Handoff docs (one-time setup runbooks)
IMPLEMENT_*.md

# Backup files
*.bak
*.tmp
*~
raw_json/
input_tsv/
.env*
/.idea/
*.zip
/CommonServerUserPython.py
# Generated config assets from release workflow
###############################################################################
# END OF FILE
###############################################################################
/output/
/scenarios/turla_carbon_cs_only.yml
/scenarios/turla_carbon_full_chain.yml
/results/
/scenarios/h8_full_chain-defender.yml

        "output_map": {
          "UC.Enrich.IP.verdict": "VirusTotal.IP.Verdict",
          "UC.Enrich.IP.detections": "VirusTotal.IP.DetectionEngines"
        }
      },
      "Recorded Future": {
        "command": "recordedfuture-intelligence",
        "inline_args": {
          "entity": "${SOCFramework.Artifacts.IP}",
          "entity_type": "ip"

        "output_map": {
          "UC.Enrich.IP.risk_score": "RecordedFuture.IP.riskScore",
          "UC.Enrich.IP.verdict": "RecordedFuture.IP.riskString"
        }
      }
    },
    "shadow_mode": false
  },

        "output_map": {
          "UC.Enrich.IP.prevalence": "Core.AnalyticsPrevalence.IP.prevalence",
          "UC.Enrich.IP.count": "Core.AnalyticsPrevalence.IP.data.global_prevalence.value"
        }
      },
      "VirusTotal (Private API)": {
        "command": "vt-private-get-ip-report",
        "inline_args": {
          "ip": "${SOCFramework.Artifacts.IP}"

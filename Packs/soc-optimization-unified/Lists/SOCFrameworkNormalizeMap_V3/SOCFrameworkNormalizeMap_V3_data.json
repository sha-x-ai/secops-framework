      "target": "Network.action",
      "issue_field": "action",
      "shape": "flat",
      "role": "canonical",
      "source_origin": "native",
      "notes": "Single value not array on observed Network dump (action: 'DETECTED'). Endpoint band uses action.[0]; Network alerts surface as scalar."
    },
    {
      "category": "network",
      "target": "Network.application",
      "issue_field": "appid.[0]",
      "shape": "flat",
      "role": "canonical",
      "source_origin": "native",
      "notes": "PAN App-ID stack as concatenated string (e.g., 'ip,tcp,ms-ds-smbv3'). Drives Analysis verdict scoring for L7 anomalies."
    },
    {
      "category": "network",
      "target": "Network.destination_country",
      "issue_field": "xdmtargetlocationcountry.[0]",
      "shape": "flat",
      "role": "canonical",
      "source_origin": "native",
      "notes": "Empty ('-') for internal-to-internal traffic on observed dump; populated for egress."
    },
    {
      "category": "network",
      "target": "Network.destination_hostname",
      "issue_field": "xdmtargethosthostname.[0]",
      "shape": "flat",
      "role": "canonical",
      "source_origin": "native"
    },
    {
      "category": "network",
      "target": "Network.destination_ip",
      "issue_field": "xdmtargetipv4.[0]",
      "shape": "flat",
      "role": "canonical",
      "source_origin": "native",
      "notes": "Drives soc-block-ip and soc-update-acl. Same value as remoteip on PANW NGFW alerts; xdmtarget chosen as canonical for cross-vendor portability."
    },
    {
      "category": "network",
      "target": "Network.destination_port",
      "issue_field": "xdmtargetport.[0]",
      "shape": "flat",
      "role": "canonical",
      "source_origin": "native"
    },
    {
      "category": "network",
      "target": "Network.destination_zone",
      "issue_field": "destinationzonename.[0]",
      "shape": "flat",
      "role": "canonical",
      "source_origin": "native",
      "notes": "Firewall destination zone (e.g., 'Infrastructure'). Network-specific concept, no analogue in Endpoint/Identity bands."
    },
    {
      "category": "network",
      "target": "Network.device_name",
      "issue_field": "fwname.[0]",
      "shape": "flat",
      "role": "canonical",
      "source_origin": "native",
      "notes": "Firewall display name. Drives vendor branch routing in SOC_Network_Containment_V3 / Recovery via SOCExecutionList_V3."
    },
    {
      "category": "network",
      "target": "Network.device_rule_name",
      "issue_field": "fwrulename.[0]",
      "shape": "flat",
      "role": "canonical",
      "source_origin": "native",
      "notes": "Pipe-delimited 'vsys|policy' form on PAN (e.g., 'rangexsiam|Lab Learning Policy'). Required by soc-update-acl and soc-restore-acl."
    },
    {
      "category": "network",
      "target": "Network.device_serial",
      "issue_field": "fwserialnumber.[0]",
      "shape": "flat",
      "role": "canonical",
      "source_origin": "native",
      "notes": "Firewall hardware serial. Required for vendor API targeting on multi-firewall deployments."
    },
    {
      "category": "network",
      "target": "Network.dns_query",
      "issue_field": "dnsqueryname",
      "shape": "flat",
      "role": "canonical",
      "source_origin": "native",
      "notes": "Native cliName, verified in prior cliName-convergence changelog (NOT dns_query_name). Not present on NGFW BIOC alerts; populated on DNS-firewall alerts (Umbrella, PAN DNS Security). Required by soc-block-domain DNS-firewall path."
    },
    {
      "category": "network",
      "target": "Network.event_type",
      "issue_field": "xdmeventtype.[0]",
      "shape": "flat",
      "role": "canonical",
      "source_origin": "native",
      "notes": "DML event classification (e.g., 'DML_CONNECTION'). Distinct from numeric eventtype which is alert-classification code."
    },
    {
      "category": "network",
      "target": "Network.source_country",
      "issue_field": "xdmsourcelocationcountry.[0]",
      "shape": "flat",
      "role": "canonical",
      "source_origin": "native",
      "notes": "'UNKNOWN' for RFC1918 sources on observed dump; populated for external sources. Drives geo-anomaly verdict signals."
    },
    {
      "category": "network",
      "target": "Network.source_hostname",
      "issue_field": "xdmsourcehosthostname",
      "shape": "flat",
      "role": "canonical",
      "source_origin": "native",
      "notes": "Single string not array on observed Network dump (cf. Identity band where the hostname cliName carries source IP for SSO alerts). On Network alerts, carries actual hostname."
    },
    {
      "category": "network",
      "target": "Network.source_ip",
      "issue_field": "xdmsourceipv4.[0]",
      "shape": "flat",
      "role": "canonical",
      "source_origin": "native",
      "notes": "Drives soc-quarantine-network targeting. Same value as localip on PANW NGFW alerts; xdmsource chosen as canonical."
    },
    {
      "category": "network",
      "target": "Network.source_port",
      "issue_field": "localport.[0]",
      "shape": "flat",
      "role": "canonical",
      "source_origin": "native",
      "notes": "Source ephemeral port. No xdmsourceport observed on dump; localport is the canonical source-port cliName."
    },
    {
      "category": "network",
      "target": "Network.source_zone",
      "issue_field": "sourcezonename.[0]",
      "shape": "flat",
      "role": "canonical",
      "source_origin": "native",
      "notes": "Firewall source zone (e.g., 'Users'). Network-specific."
    }

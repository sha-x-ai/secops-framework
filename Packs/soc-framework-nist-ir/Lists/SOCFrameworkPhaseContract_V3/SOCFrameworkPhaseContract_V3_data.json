{
  "phases": {
    "analysis": {
      "orchestrator": "SOC_Analysis_V3",
      "requires_phase": null,
      "purpose": "Determine verdict, confidence, scope, and recommended response from raw alerts and SOCFramework artifacts."
    },
    "containment": {
      "orchestrator": "SOC_Containment_V3",
      "requires_phase": "analysis",
      "purpose": "Stop the spread — isolate hosts, block users, quarantine email."
    },
    "eradication": {
      "orchestrator": "SOC_Eradication_V3",
      "requires_phase": "containment",
      "purpose": "Remove persistence and remediate compromised entities."
    },
    "recovery": {
      "orchestrator": "SOC_Recovery_V3",
      "requires_phase": "eradication",
      "purpose": "Restore systems to known-good state and establish monitoring."
    }
  },
  "categories": [
    "endpoint",
    "email",
    "identity"
  ],

[MODEL: dataset=issues]
filter xdm.issue.detection.method = "XPANSE"
| alter
    xdm.alert.original_alert_id = xdm.issue.id,
    xdm.alert.name = xdm.issue.name,
    xdm.alert.description = xdm.issue.description,
    xdm.alert.severity = xdm.issue.severity,
    xdm.alert.category = xdm.issue.category,
    xdm.observer.vendor = "Palo Alto Networks",
    xdm.observer.product = "Cortex Xpanse";
